{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm run build",
  "crons": [
    {
      "path": "/api/cron/mark-overdue",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/contract-alerts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/monthly-summary",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/monthly-report",
      "schedule": "0 9 5 * *"
    },
    {
      "path": "/api/cron/create-monthly-payments",
      "schedule": "0 6 1 * *"
    }
    ,
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "0 9 * * *"
    }
    ,
    {
      "path": "/api/cron/process-whatsapp",
      "schedule": "0 * * * *"
    }
  ]
}
