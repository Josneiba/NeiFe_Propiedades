generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  role              Role
  password          String
  avatar            String?
  phone             String?
  company           String?
  rut               String?   @unique
  documentCountry   DocumentCountry?
  documentType      DocumentType?
  documentNumber    String?
  documentNumberNormalized String?
  isActive          Boolean   @default(true)
  emailVerified     DateTime?
  onboardingDone    Boolean   @default(false)
  privacyAccepted   Boolean   @default(false)
  privacyAcceptedAt DateTime?
  bankName          String?
  bankAccountType   String?
  bankAccountNumber String?
  bankEmail         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  ownedProperties        Property[]           @relation("LandlordProperties")
  managedProperties      Property[]           @relation("ManagedProperties")
  rentedProperty         Property?            @relation("TenantProperty")
  maintenanceReports     MaintenanceRequest[] @relation("MaintenanceRequester")
  invitationsSent        Invitation[]         @relation("InvitationSender")
  invitationsReceived    Invitation[]         @relation("InvitationReceiver")
  mandatesAsOwner        Mandate[]            @relation("MandateOwner")
  mandatesAsBroker       Mandate[]            @relation("MandateBroker")
  notifications          Notification[]
  notificationPreferences NotificationPreferences?
  activityLogs           ActivityLog[]
  accounts               Account[]
  sessions               Session[]
  calendarEvents         CalendarEvent[]
  landlordPermissions    BrokerPermission[]   @relation("LandlordPermissions")
  brokerPermissions      BrokerPermission[]   @relation("BrokerPermissions")
  brokerAccessRequests   PropertyAccessRequest[] @relation("BrokerAccessRequests")
  landlordAccessRequests PropertyAccessRequest[] @relation("LandlordAccessRequests")
  brokerStatementsSent   BrokerStatement[]    @relation("BrokerStatementBroker")
  landlordStatementsReceived BrokerStatement[] @relation("BrokerStatementLandlord")
  brokerMessagesSent     BrokerMessage[]      @relation("BrokerMessageSender")
  brokerMessagesReceived BrokerMessage[]      @relation("BrokerMessageTenant")

  @@unique([documentCountry, documentType, documentNumberNormalized])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Property {
  id             String    @id @default(cuid())
  name           String
  address        String
  commune        String
  region         String    @default("Metropolitana")
  description    String?
  bedrooms       Int?
  bathrooms      Int?
  squareMeters   Float?
  lat            Float?
  lng            Float?
  landlordId     String
  managedBy      String?
  tenantId       String?   @unique
  isActive       Boolean   @default(true)
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  applicationOpen Boolean  @default(false)
  applicationSlug String?  @unique
  contractStart  DateTime?
  contractEnd    DateTime?
  monthlyRentUF  Float?
  monthlyRentCLP Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  landlord       User      @relation("LandlordProperties", fields: [landlordId], references: [id])
  managedByUser  User?     @relation("ManagedProperties", fields: [managedBy], references: [id])
  tenant         User?     @relation("TenantProperty", fields: [tenantId], references: [id])

  // Datos del corredor/agente
  agentId         String?
  agentName       String?
  agentRut        String?
  agentEmail      String?
  agentPhone      String?
  agentCompany    String?
  commissionRate  Float?
  commissionType  CommissionType?
  commissionPaidUntil DateTime?
  commissionNotes String?

  // Inspecciones e IPC
  inspectionFrequencyMonths Int?
  nextInspectionDate        DateTime?
  ipcAdjustmentMonths       Int?
  nextIpcDate               DateTime?
  lastIpcRate               Float?

  payments       Payment[]
  services       MonthlyService[]
  maintenance    MaintenanceRequest[]
  contracts      Contract[]
  photos         PropertyPhoto[]
  invitations    Invitation[]
  providers      PropertyProvider[]
  activityLogs   ActivityLog[]
  inspections    PropertyInspection[]
  ipcAdjustments IpcAdjustment[]
  rentAdjustments RentAdjustment[]
  calendarEvents CalendarEvent[]
  mandates       Mandate[]
  accessRequests PropertyAccessRequest[]
  brokerStatements BrokerStatement[]
  brokerMessages BrokerMessage[]
  applications   TenantApplication[]
  securityDeposit SecurityDeposit?
  checklists     PropertyChecklist[]
}

model RentAdjustment {
  id            String   @id @default(cuid())
  propertyId    String
  previousCLP   Int
  newCLP        Int
  previousUF    Float?
  newUF         Float?
  reason        String
  ipcRate       Float?
  effectiveDate DateTime
  createdBy     String
  notes         String?
  createdAt     DateTime @default(now())

  property      Property @relation(fields: [propertyId], references: [id])
}

model Mandate {
  id              String        @id @default(cuid())
  propertyId      String
  ownerId         String
  brokerId        String
  status          MandateStatus @default(PENDING)
  signedByOwner   Boolean       @default(false)
  signedByBroker  Boolean       @default(false)
  ownerSignedAt   DateTime?
  brokerSignedAt  DateTime?
  startsAt        DateTime?
  expiresAt       DateTime?
  commissionRate  Float?
  commissionType  CommissionType? @default(MONTHLY)
  documentNumber  String?
  documentHash    String?
  documentGeneratedAt DateTime?
  documentSnapshot Json?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  property        Property      @relation(fields: [propertyId], references: [id])
  owner           User          @relation("MandateOwner", fields: [ownerId], references: [id])
  broker          User          @relation("MandateBroker", fields: [brokerId], references: [id])
}

model Invitation {
  id         String           @id @default(cuid())
  type       InvitationType
  email      String?
  token      String           @unique @default(cuid())
  propertyId String?
  senderId   String
  receiverId String?
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  createdAt  DateTime         @default(now())

  property   Property? @relation(fields: [propertyId], references: [id])
  sender     User     @relation("InvitationSender", fields: [senderId], references: [id])
  receiver   User?    @relation("InvitationReceiver", fields: [receiverId], references: [id])
}

model Payment {
  id         String        @id @default(cuid())
  propertyId String
  month      Int
  year       Int
  amountUF   Float
  amountCLP  Int
  status     PaymentStatus @default(PENDING)
  method     String?
  paidAt     DateTime?
  receipt    String?
  notes      String?
  createdAt  DateTime      @default(now())

  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, month, year])
}

model MonthlyService {
  id              String   @id @default(cuid())
  propertyId      String
  month           Int
  year            Int

  // Servicios básicos
  water           Int      @default(0)
  waterBillUrl    String?

  electricity     Int      @default(0)
  lightBillUrl    String?

  gas             Int      @default(0)
  gasBillUrl      String?

  // Nuevos servicios
  garbage         Int      @default(0)
  garbageBillUrl  String?

  commonExpenses  Int      @default(0)
  commonBillUrl   String?

  // Ítems adicionales personalizados (JSON)
  extraItems      Json?    // Array de { label, amount, billUrl }

  // Campos legacy (mantener compatibilidad)
  other           Int      @default(0)
  otherLabel      String?

  // Notas del período
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property        Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, month, year])
}

model MaintenanceRequest {
  id              String              @id @default(cuid())
  propertyId      String
  requesterId     String
  category        MaintenanceCategory
  description     String
  photos          String[]
  isLandlordResp  Boolean             @default(true)
  legalReference  String?
  status          MaintenanceStatus   @default(REQUESTED)
  providerId      String?
  invoiceUrl      String?
  invoiceAmount   Int?
  rejectionReason String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  property        Property            @relation(fields: [propertyId], references: [id])
  requester       User                @relation("MaintenanceRequester", fields: [requesterId], references: [id])
  provider        Provider?           @relation(fields: [providerId], references: [id])
  timeline        MaintenanceTimeline[]
}

model MaintenanceTimeline {
  id        String            @id @default(cuid())
  requestId String
  status    MaintenanceStatus
  note      String?
  createdAt DateTime          @default(now())

  request   MaintenanceRequest @relation(fields: [requestId], references: [id])
}

model PropertyInspection {
  id            String           @id @default(cuid())
  propertyId    String
  scheduledAt   DateTime
  type          InspectionType
  status        InspectionStatus @default(SCHEDULED)
  notes         String?
  completedAt   DateTime?
  reportUrl     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  property      Property         @relation(fields: [propertyId], references: [id])
}

model IpcAdjustment {
  id              String    @id @default(cuid())
  propertyId      String
  scheduledDate   DateTime
  ipcRate         Float?
  previousRentCLP Int
  newRentCLP      Int?
  status          IpcStatus @default(PENDING)
  appliedAt       DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  property        Property  @relation(fields: [propertyId], references: [id])
}

model Contract {
  id            String         @id @default(cuid())
  propertyId    String
  pdfUrl        String?
  landlordSign  String?
  tenantSign    String?
  hash          String?
  status        ContractStatus @default(DRAFT)
  signedAt      DateTime?
  startDate     DateTime?
  endDate       DateTime?
  rentUF        Float?
  createdAt     DateTime       @default(now())

  property      Property       @relation(fields: [propertyId], references: [id])
}

model PropertyPhoto {
  id         String    @id @default(cuid())
  propertyId String
  url        String
  type       PhotoType
  room       String
  caption    String?
  order      Int       @default(0)
  takenAt    DateTime  @default(now())

  property   Property  @relation(fields: [propertyId], references: [id])
}

model Provider {
  id          String            @id @default(cuid())
  name        String
  specialty   ProviderSpecialty
  phone       String
  email       String?
  photoUrl    String?
  description String?
  rating      Float?
  isActive    Boolean           @default(true)
  landlordId  String
  createdAt   DateTime          @default(now())

  properties  PropertyProvider[]
  maintenance MaintenanceRequest[]
}

model PropertyProvider {
  propertyId String
  providerId String
  assignedAt DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id])
  provider   Provider @relation(fields: [providerId], references: [id])

  @@id([propertyId, providerId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String    @id @default(cuid())
  userId      String
  propertyId  String?
  action      String
  description String
  metadata    Json?
  createdAt   DateTime  @default(now())

  user        User     @relation(fields: [userId], references: [id])
  property    Property? @relation(fields: [propertyId], references: [id])
}

model NotificationPreferences {
  id     String @id @default(cuid())
  userId String @unique

  // Inspecciones
  notifyTenantInspection Boolean @default(true)
  inspectionReminderDays Int     @default(3)

  // Pagos
  notifyPaymentReminder  Boolean @default(true)
  paymentReminderDays    Int     @default(5)

  // Contratos
  notifyContractExpiring Boolean @default(true)
  contractWarningDays    Int     @default(30)

  // IPC
  notifyIpcDue           Boolean @default(true)
  ipcReminderDays        Int     @default(14)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  OWNER
  LANDLORD
  BROKER
  TENANT
  PROVIDER
}

enum DocumentCountry {
  CL
  AR
  PE
  CO
  MX
  US
  ES
  OTHER
}

enum DocumentType {
  RUT
  DNI
  CEDULA
  PASSPORT
  RFC
  CURP
  NIF_NIE
  OTHER
}

enum MandateStatus {
  PENDING
  ACTIVE
  REVOKED
  EXPIRED
}

enum InvitationType {
  EMAIL
  LINK
  BROKER_INVITE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  PROCESSING
  CANCELLED
}

enum MaintenanceStatus {
  REQUESTED
  REVIEWING
  APPROVED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  STRUCTURAL
  APPLIANCES
  CLEANING
  OTHER
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURES
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  INSPECTION_SCHEDULED
  INSPECTION_CONFIRMED
  IPC_ADJUSTMENT_APPLIED
}

enum CommissionType {
  MONTHLY
  ONE_TIME
  ANNUAL
}

enum InspectionType {
  ROUTINE
  CHECKIN
  CHECKOUT
  MAINTENANCE
  IPC_REVIEW
}

enum InspectionStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum IpcStatus {
  PENDING
  APPLIED
  SKIPPED
  TERMINATED
}

enum PhotoType {
  CHECKIN
  CHECKOUT
  CURRENT
  MAINTENANCE
}

enum ProviderSpecialty {
  PLUMBER
  ELECTRICIAN
  PAINTER
  CARPENTER
  LOCKSMITH
  GENERAL
  OTHER
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_RECEIVED
  PAYMENT_OVERDUE
  MANDATE_REQUESTED
  MANDATE_SIGNED
  MANDATE_REVOKED
  MAINTENANCE_NEW
  MAINTENANCE_UPDATE
  CONTRACT_EXPIRING
  CONTRACT_SIGNED
  SERVICE_UPLOADED
  INVITATION_RECEIVED
  SYSTEM
}

enum BrokerStatementStatus {
  DRAFT
  SENT
}

enum BrokerStatementItemType {
  COMMISSION
  MAINTENANCE
  DEDUCTION
}

enum BrokerMessageType {
  GENERAL
  PAYMENT_REMINDER
  MAINTENANCE_VISIT
  CONTRACT_NOTICE
}

enum CalendarEventType {
  INSPECTION
  PAYMENT_DUE
  CONTRACT_RENEWAL
  IPC_ADJUSTMENT
  MAINTENANCE
  TENANT_REMINDER
  OTHER
}

model CalendarEvent {
  id        String   @id @default(cuid())
  title     String
  description String?
  type      CalendarEventType
  date      DateTime
  reminder  Int?    // Días antes para recordatorio
  notifyTenant Boolean @default(false)
  propertyId String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  creator   User     @relation(fields: [createdBy], references: [id])
}

enum PermissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model BrokerPermission {
  id          String   @id @default(cuid())
  landlordId  String
  brokerId    String
  status      PermissionStatus @default(PENDING)
  approvedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  landlord    User     @relation("LandlordPermissions", fields: [landlordId], references: [id])
  broker      User     @relation("BrokerPermissions", fields: [brokerId], references: [id])

  @@unique([landlordId, brokerId])
}

model PropertyAccessRequest {
  id         String   @id @default(cuid())
  propertyId String
  brokerId   String
  landlordId String
  message    String?
  status     PermissionStatus @default(PENDING)
  approvedAt DateTime?
  rejectedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property   Property @relation(fields: [propertyId], references: [id])
  broker     User     @relation("BrokerAccessRequests", fields: [brokerId], references: [id])
  landlord   User     @relation("LandlordAccessRequests", fields: [landlordId], references: [id])

  @@unique([propertyId, brokerId])
}

model BrokerStatement {
  id                  String                 @id @default(cuid())
  brokerId            String
  landlordId          String
  propertyId          String
  month               Int
  year                Int
  grossIncomeCLP      Int
  brokerCommissionCLP Int
  maintenanceCLP      Int                    @default(0)
  otherDeductionsCLP  Int                    @default(0)
  netTransferCLP      Int
  notes               String?
  transferReference   String?
  transferDate        DateTime?
  status              BrokerStatementStatus  @default(DRAFT)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  broker              User                   @relation("BrokerStatementBroker", fields: [brokerId], references: [id])
  landlord            User                   @relation("BrokerStatementLandlord", fields: [landlordId], references: [id])
  property            Property               @relation(fields: [propertyId], references: [id])
  items               BrokerStatementItem[]

  @@unique([propertyId, month, year])
}

model BrokerStatementItem {
  id          String                  @id @default(cuid())
  statementId String
  label       String
  amountCLP   Int
  type        BrokerStatementItemType
  notes       String?
  createdAt   DateTime                @default(now())

  statement   BrokerStatement         @relation(fields: [statementId], references: [id], onDelete: Cascade)
}

model BrokerMessage {
  id          String            @id @default(cuid())
  propertyId  String
  senderId    String
  tenantId    String
  subject     String
  message     String
  type        BrokerMessageType @default(GENERAL)
  sendEmail   Boolean           @default(false)
  emailStatus EmailDeliveryStatus @default(NOT_REQUESTED)
  emailProviderId String?
  emailError  String?
  createdAt   DateTime          @default(now())

  property    Property          @relation(fields: [propertyId], references: [id])
  sender      User              @relation("BrokerMessageSender", fields: [senderId], references: [id])
  tenant      User              @relation("BrokerMessageTenant", fields: [tenantId], references: [id])
}

enum EmailDeliveryStatus {
  NOT_REQUESTED
  SENT
  FAILED
}

model TenantApplication {
  id              String            @id @default(cuid())
  propertyId      String
  name            String
  email           String
  phone           String
  rut             String
  monthlyIncome   Int
  currentEmployer String?
  message         String?
  status          ApplicationStatus @default(PENDING)
  documents       String[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  property        Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}

model SecurityDeposit {
  id                String        @id @default(cuid())
  propertyId        String        @unique
  amountCLP         Int
  receivedAt        DateTime
  receivedBy        String
  status            DepositStatus @default(HELD)
  returnedAt        DateTime?
  returnedAmountCLP Int?
  deductionsCLP     Int?
  deductionNotes    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  property          Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyChecklist {
  id                String        @id @default(cuid())
  propertyId        String
  type              ChecklistType
  completedAt       DateTime?
  completedBy       String
  rooms             Json
  overallCondition  String?
  tenantSignature   String?
  landlordSignature String?
  createdAt         DateTime      @default(now())

  property          Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

enum DepositStatus {
  HELD
  RETURNED_FULL
  RETURNED_PARTIAL
  FORFEITED
}

enum ChecklistType {
  CHECKIN
  CHECKOUT
}
