generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  role              Role
  password          String
  avatar            String?
  phone             String?
  company           String?
  rut               String?   @unique
  documentCountry   DocumentCountry?
  documentType      DocumentType?
  documentNumber    String?
  documentNumberNormalized String?
  isActive          Boolean   @default(true)
  emailVerified     DateTime?
  onboardingDone    Boolean   @default(false)
  privacyAccepted   Boolean   @default(false)
  privacyAcceptedAt DateTime?
  bankName          String?
  bankAccountType   String?
  bankAccountNumber String?
  bankEmail         String?
  
  // Broker settings
  dailyContactGoal  Int       @default(10)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  ownedProperties        Property[]           @relation("LandlordProperties")
  managedProperties      Property[]           @relation("ManagedProperties")
  rentedProperty         Property?            @relation("TenantProperty")
  maintenanceReports     MaintenanceRequest[] @relation("MaintenanceRequester")
  invitationsSent        Invitation[]         @relation("InvitationSender")
  invitationsReceived    Invitation[]         @relation("InvitationReceiver")
  mandatesAsOwner        Mandate[]            @relation("MandateOwner")
  mandatesAsBroker       Mandate[]            @relation("MandateBroker")
  notifications          Notification[]
  notificationPreferences NotificationPreferences?
  activityLogs           ActivityLog[]
  accounts               Account[]
  sessions               Session[]
  calendarEvents         CalendarEvent[]
  landlordPermissions    BrokerPermission[]   @relation("LandlordPermissions")
  brokerPermissions      BrokerPermission[]   @relation("BrokerPermissions")
  brokerAccessRequests   PropertyAccessRequest[] @relation("BrokerAccessRequests")
  landlordAccessRequests PropertyAccessRequest[] @relation("LandlordAccessRequests")
  brokerStatementsSent   BrokerStatement[]    @relation("BrokerStatementBroker")
  landlordStatementsReceived BrokerStatement[] @relation("BrokerStatementLandlord")
  brokerMessagesSent     BrokerMessage[]      @relation("BrokerMessageSender")
  brokerMessagesReceived BrokerMessage[]      @relation("BrokerMessageTenant")
  propertyCreationRequestsAsBroker BrokerPropertyCreationRequest[] @relation("BrokerPropertyCreationBroker")
  propertyCreationRequestsAsLandlord BrokerPropertyCreationRequest[] @relation("BrokerPropertyCreationLandlord")

  // CRM relations (Fase CRM Junio 2026)
  crmContacts       CrmContact[]   @relation("CrmBrokerContacts")
  crmProperties     CrmProperty[]  @relation("CrmBrokerProperties")
  crmDeals          CrmDeal[]      @relation("CrmBrokerDeals")
  crmDealsAsLandlord CrmDeal[]     @relation("CrmDealLandlord")
  crmActivities     CrmActivity[]  @relation("CrmBrokerActivities")
  stageHistoryEntries CrmDealStageHistory[] @relation("StageHistoryBroker")
  dealAttachments   CrmDealAttachment[] @relation("DealAttachmentUploader")

  // PARTE 6 relations
  sequenceTemplates CrmDealSequenceTemplate[] @relation("SequenceTemplates")
  sequencesCreated  CrmDealSequence[] @relation("SequencesCreated")
  brokerIntegrations BrokerIntegration[] @relation("BrokerIntegrations")
  whatsappMessages  WhatsAppMessage[] @relation("WhatsAppMessages")
  whatsappTemplates WhatsAppTemplate[] @relation("WhatsAppTemplates")
  brokerGoals        BrokerGoal[]         @relation("BrokerGoals")
  brokerWeekPlans    BrokerWeekPlan[]     @relation("BrokerWeekPlans")

  // FASE VIXIEES — Task Engine + Playbook + Templates
  brokerTasks        CrmTask[]            @relation("BrokerTasks")
  brokerPlaybook     CrmPlaybookStep[]    @relation("BrokerPlaybook")
  messageTemplates   CrmMessageTemplate[] @relation("BrokerMessageTemplates")

  @@unique([documentCountry, documentType, documentNumberNormalized])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Property {
  id             String    @id @default(cuid())
  name           String
  address        String
  commune        String
  region         String    @default("Metropolitana")
  description    String?
  bedrooms       Int?
  bathrooms      Int?
  squareMeters   Float?
  lat            Float?
  lng            Float?
  landlordId     String
  managedBy      String?
  tenantId       String?   @unique
  isActive       Boolean   @default(true)
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  applicationOpen Boolean  @default(false)
  applicationSlug String?  @unique
  contractStart  DateTime?
  contractEnd    DateTime?
  monthlyRentUF  Float?
  monthlyRentCLP Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  landlord       User      @relation("LandlordProperties", fields: [landlordId], references: [id])
  managedByUser  User?     @relation("ManagedProperties", fields: [managedBy], references: [id])
  tenant         User?     @relation("TenantProperty", fields: [tenantId], references: [id])

  // Datos del corredor/agente
  agentId         String?
  agentName       String?
  agentRut        String?
  agentEmail      String?
  agentPhone      String?
  agentCompany    String?
  commissionRate  Float?
  commissionType  CommissionType?
  commissionPaidUntil DateTime?
  commissionNotes String?

  // Inspecciones e IPC
  inspectionFrequencyMonths Int?
  nextInspectionDate        DateTime?
  ipcAdjustmentMonths       Int?
  nextIpcDate               DateTime?
  lastIpcRate               Float?

  payments       Payment[]
  services       MonthlyService[]
  maintenance    MaintenanceRequest[]
  contracts      Contract[]
  photos         PropertyPhoto[]
  invitations    Invitation[]
  providers      PropertyProvider[]
  activityLogs   ActivityLog[]
  inspections    PropertyInspection[]
  ipcAdjustments IpcAdjustment[]
  rentAdjustments RentAdjustment[]
  calendarEvents CalendarEvent[]
  mandates       Mandate[]
  accessRequests PropertyAccessRequest[]
  brokerStatements BrokerStatement[]
  brokerMessages BrokerMessage[]
  applications   TenantApplication[]
  securityDeposit SecurityDeposit?
  checklists     PropertyChecklist[]
  creationRequests BrokerPropertyCreationRequest[]
}

model RentAdjustment {
  id            String   @id @default(cuid())
  propertyId    String
  previousCLP   Int
  newCLP        Int
  previousUF    Float?
  newUF         Float?
  reason        String
  ipcRate       Float?
  effectiveDate DateTime
  createdBy     String
  notes         String?
  createdAt     DateTime @default(now())

  property      Property @relation(fields: [propertyId], references: [id])
}

model Mandate {
  id              String        @id @default(cuid())
  propertyId      String
  ownerId         String
  brokerId        String
  status          MandateStatus @default(PENDING)
  signedByOwner   Boolean       @default(false)
  signedByBroker  Boolean       @default(false)
  ownerSignedAt   DateTime?
  brokerSignedAt  DateTime?
  startsAt        DateTime?
  expiresAt       DateTime?
  commissionRate  Float?
  commissionType  CommissionType? @default(MONTHLY)
  documentNumber  String?
  documentHash    String?
  documentGeneratedAt DateTime?
  documentSnapshot Json?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  property        Property      @relation(fields: [propertyId], references: [id])
  owner           User          @relation("MandateOwner", fields: [ownerId], references: [id])
  broker          User          @relation("MandateBroker", fields: [brokerId], references: [id])
}

model Invitation {
  id         String           @id @default(cuid())
  type       InvitationType
  email      String?
  token      String           @unique @default(cuid())
  propertyId String?
  senderId   String
  receiverId String?
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  createdAt  DateTime         @default(now())

  property   Property? @relation(fields: [propertyId], references: [id])
  sender     User     @relation("InvitationSender", fields: [senderId], references: [id])
  receiver   User?    @relation("InvitationReceiver", fields: [receiverId], references: [id])
}

model Payment {
  id         String        @id @default(cuid())
  propertyId String
  month      Int
  year       Int
  amountUF   Float
  amountCLP  Int
  status     PaymentStatus @default(PENDING)
  method     String?
  paidAt     DateTime?
  receipt    String?
  notes      String?
  createdAt  DateTime      @default(now())

  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, month, year])
}

model MonthlyService {
  id              String   @id @default(cuid())
  propertyId      String
  month           Int
  year            Int

  // Servicios básicos
  water           Int      @default(0)
  waterBillUrl    String?

  electricity     Int      @default(0)
  lightBillUrl    String?

  gas             Int      @default(0)
  gasBillUrl      String?

  // Nuevos servicios
  garbage         Int      @default(0)
  garbageBillUrl  String?

  commonExpenses  Int      @default(0)
  commonBillUrl   String?

  // Ítems adicionales personalizados (JSON)
  extraItems      Json?    // Array de { label, amount, billUrl }

  // Campos legacy (mantener compatibilidad)
  other           Int      @default(0)
  otherLabel      String?

  // Notas del período
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property        Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, month, year])
}

model MaintenanceRequest {
  id              String              @id @default(cuid())
  propertyId      String
  requesterId     String
  category        MaintenanceCategory
  description     String
  photos          String[]
  isLandlordResp  Boolean             @default(true)
  legalReference  String?
  status          MaintenanceStatus   @default(REQUESTED)
  providerId      String?
  invoiceUrl      String?
  invoiceAmount   Int?
  rejectionReason String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  property        Property            @relation(fields: [propertyId], references: [id])
  requester       User                @relation("MaintenanceRequester", fields: [requesterId], references: [id])
  provider        Provider?           @relation(fields: [providerId], references: [id])
  timeline        MaintenanceTimeline[]
}

model MaintenanceTimeline {
  id        String            @id @default(cuid())
  requestId String
  status    MaintenanceStatus
  note      String?
  createdAt DateTime          @default(now())

  request   MaintenanceRequest @relation(fields: [requestId], references: [id])
}

model PropertyInspection {
  id            String           @id @default(cuid())
  propertyId    String
  scheduledAt   DateTime
  type          InspectionType
  status        InspectionStatus @default(SCHEDULED)
  notes         String?
  completedAt   DateTime?
  reportUrl     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  property      Property         @relation(fields: [propertyId], references: [id])
}

model IpcAdjustment {
  id              String    @id @default(cuid())
  propertyId      String
  scheduledDate   DateTime
  ipcRate         Float?
  previousRentCLP Int
  newRentCLP      Int?
  status          IpcStatus @default(PENDING)
  appliedAt       DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  property        Property  @relation(fields: [propertyId], references: [id])
}

model Contract {
  id            String         @id @default(cuid())
  propertyId    String
  pdfUrl        String?
  landlordSign  String?
  tenantSign    String?
  hash          String?
  status        ContractStatus @default(DRAFT)
  signedAt      DateTime?
  startDate     DateTime?
  endDate       DateTime?
  rentUF        Float?
  createdAt     DateTime       @default(now())

  property      Property       @relation(fields: [propertyId], references: [id])
}

model PropertyPhoto {
  id         String    @id @default(cuid())
  propertyId String
  url        String
  type       PhotoType
  room       String
  caption    String?
  order      Int       @default(0)
  takenAt    DateTime  @default(now())

  property   Property  @relation(fields: [propertyId], references: [id])
}

model Provider {
  id          String            @id @default(cuid())
  name        String
  specialty   ProviderSpecialty
  phone       String
  email       String?
  photoUrl    String?
  description String?
  rating      Float?
  isActive    Boolean           @default(true)
  landlordId  String
  createdAt   DateTime          @default(now())

  properties  PropertyProvider[]
  maintenance MaintenanceRequest[]
}

model PropertyProvider {
  propertyId String
  providerId String
  assignedAt DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id])
  provider   Provider @relation(fields: [providerId], references: [id])

  @@id([propertyId, providerId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String    @id @default(cuid())
  userId      String
  propertyId  String?
  action      String
  description String
  metadata    Json?
  createdAt   DateTime  @default(now())

  user        User     @relation(fields: [userId], references: [id])
  property    Property? @relation(fields: [propertyId], references: [id])
}

model NotificationPreferences {
  id     String @id @default(cuid())
  userId String @unique

  // Inspecciones
  notifyTenantInspection Boolean @default(true)
  inspectionReminderDays Int     @default(3)

  // Pagos
  notifyPaymentReminder  Boolean @default(true)
  paymentReminderDays    Int     @default(5)

  // Contratos
  notifyContractExpiring Boolean @default(true)
  contractWarningDays    Int     @default(30)

  // IPC
  notifyIpcDue           Boolean @default(true)
  ipcReminderDays        Int     @default(14)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrokerPropertyCreationRequest {
  id          String                       @id @default(cuid())
  propertyId  String
  brokerId    String
  landlordId  String
  status      BrokerPropertyCreationStatus @default(PENDING)
  ownerName   String?
  ownerEmail  String
  notes       String?
  reviewedAt  DateTime?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  broker      User     @relation("BrokerPropertyCreationBroker", fields: [brokerId], references: [id])
  landlord    User     @relation("BrokerPropertyCreationLandlord", fields: [landlordId], references: [id])

  @@index([brokerId, status])
  @@index([landlordId, status])
  @@unique([propertyId])
}

enum Role {
  OWNER
  LANDLORD
  BROKER
  TENANT
  PROVIDER
}

enum DocumentCountry {
  CL
  AR
  PE
  CO
  MX
  US
  ES
  OTHER
}

enum DocumentType {
  RUT
  DNI
  CEDULA
  PASSPORT
  RFC
  CURP
  NIF_NIE
  OTHER
}

enum MandateStatus {
  PENDING
  ACTIVE
  REVOKED
  EXPIRED
}

enum InvitationType {
  EMAIL
  LINK
  BROKER_INVITE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  PROCESSING
  CANCELLED
}

enum MaintenanceStatus {
  REQUESTED
  REVIEWING
  APPROVED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  STRUCTURAL
  APPLIANCES
  CLEANING
  OTHER
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURES
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  INSPECTION_SCHEDULED
  INSPECTION_CONFIRMED
  IPC_ADJUSTMENT_APPLIED
}

enum CommissionType {
  MONTHLY
  ONE_TIME
  ANNUAL
}

enum InspectionType {
  ROUTINE
  CHECKIN
  CHECKOUT
  MAINTENANCE
  IPC_REVIEW
}

enum InspectionStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum IpcStatus {
  PENDING
  APPLIED
  SKIPPED
  TERMINATED
}

enum PhotoType {
  CHECKIN
  CHECKOUT
  CURRENT
  MAINTENANCE
}

enum ProviderSpecialty {
  PLUMBER
  ELECTRICIAN
  PAINTER
  CARPENTER
  LOCKSMITH
  GENERAL
  OTHER
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_RECEIVED
  PAYMENT_OVERDUE
  MANDATE_REQUESTED
  MANDATE_SIGNED
  MANDATE_REVOKED
  MAINTENANCE_NEW
  MAINTENANCE_UPDATE
  CONTRACT_EXPIRING
  CONTRACT_SIGNED
  SERVICE_UPLOADED
  INVITATION_RECEIVED
  SYSTEM
}

enum BrokerPropertyCreationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BrokerStatementStatus {
  DRAFT
  SENT
}

enum BrokerStatementItemType {
  COMMISSION
  MAINTENANCE
  DEDUCTION
}

enum BrokerMessageType {
  GENERAL
  PAYMENT_REMINDER
  MAINTENANCE_VISIT
  CONTRACT_NOTICE
}

enum CalendarEventType {
  INSPECTION
  PAYMENT_DUE
  CONTRACT_RENEWAL
  IPC_ADJUSTMENT
  MAINTENANCE
  TENANT_REMINDER
  OTHER
}

model CalendarEvent {
  id        String   @id @default(cuid())
  title     String
  description String?
  type      CalendarEventType
  date      DateTime
  reminder  Int?    // Días antes para recordatorio
  notifyTenant Boolean @default(false)
  propertyId String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  creator   User     @relation(fields: [createdBy], references: [id])
}

enum PermissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model BrokerPermission {
  id          String   @id @default(cuid())
  landlordId  String
  brokerId    String
  status      PermissionStatus @default(PENDING)
  approvedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  landlord    User     @relation("LandlordPermissions", fields: [landlordId], references: [id])
  broker      User     @relation("BrokerPermissions", fields: [brokerId], references: [id])

  @@unique([landlordId, brokerId])
}

model PropertyAccessRequest {
  id         String   @id @default(cuid())
  propertyId String
  brokerId   String
  landlordId String
  message    String?
  status     PermissionStatus @default(PENDING)
  approvedAt DateTime?
  rejectedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property   Property @relation(fields: [propertyId], references: [id])
  broker     User     @relation("BrokerAccessRequests", fields: [brokerId], references: [id])
  landlord   User     @relation("LandlordAccessRequests", fields: [landlordId], references: [id])

  @@unique([propertyId, brokerId])
}

model BrokerStatement {
  id                  String                 @id @default(cuid())
  brokerId            String
  landlordId          String
  propertyId          String
  month               Int
  year                Int
  grossIncomeCLP      Int
  brokerCommissionCLP Int
  maintenanceCLP      Int                    @default(0)
  otherDeductionsCLP  Int                    @default(0)
  netTransferCLP      Int
  notes               String?
  transferReference   String?
  transferDate        DateTime?
  status              BrokerStatementStatus  @default(DRAFT)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  broker              User                   @relation("BrokerStatementBroker", fields: [brokerId], references: [id])
  landlord            User                   @relation("BrokerStatementLandlord", fields: [landlordId], references: [id])
  property            Property               @relation(fields: [propertyId], references: [id])
  items               BrokerStatementItem[]

  @@unique([propertyId, month, year])
}

model BrokerStatementItem {
  id          String                  @id @default(cuid())
  statementId String
  label       String
  amountCLP   Int
  type        BrokerStatementItemType
  notes       String?
  createdAt   DateTime                @default(now())

  statement   BrokerStatement         @relation(fields: [statementId], references: [id], onDelete: Cascade)
}

model BrokerMessage {
  id          String            @id @default(cuid())
  propertyId  String
  senderId    String
  tenantId    String
  subject     String
  message     String
  isRead      Boolean           @default(false)
  type        BrokerMessageType @default(GENERAL)
  sendEmail   Boolean           @default(false)
  emailStatus EmailDeliveryStatus @default(NOT_REQUESTED)
  emailProviderId String?
  emailError  String?
  createdAt   DateTime          @default(now())

  property    Property          @relation(fields: [propertyId], references: [id])
  sender      User              @relation("BrokerMessageSender", fields: [senderId], references: [id])
  tenant      User              @relation("BrokerMessageTenant", fields: [tenantId], references: [id])
}

enum EmailDeliveryStatus {
  NOT_REQUESTED
  SENT
  FAILED
}

model TenantApplication {
  id              String            @id @default(cuid())
  propertyId      String
  name            String
  email           String
  phone           String
  rut             String
  monthlyIncome   Int
  currentEmployer String?
  message         String?
  status          ApplicationStatus @default(PENDING)
  documents       String[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  property        Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}

model SecurityDeposit {
  id                String        @id @default(cuid())
  propertyId        String        @unique
  amountCLP         Int
  receivedAt        DateTime
  receivedBy        String
  status            DepositStatus @default(HELD)
  returnedAt        DateTime?
  returnedAmountCLP Int?
  deductionsCLP     Int?
  deductionNotes    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  property          Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyChecklist {
  id                String        @id @default(cuid())
  propertyId        String
  type              ChecklistType
  completedAt       DateTime?
  completedBy       String
  rooms             Json
  overallCondition  String?
  tenantSignature   String?
  landlordSignature String?
  createdAt         DateTime      @default(now())

  property          Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

enum DepositStatus {
  HELD
  RETURNED_FULL
  RETURNED_PARTIAL
  FORFEITED
}

enum ChecklistType {
  CHECKIN
  CHECKOUT
}

// ─────────────────────────────────────────────────────────────
// CRM MODULE — Agregado en Fase CRM (Junio 2026)
// ─────────────────────────────────────────────────────────────

model CrmContact {
  id        String           @id @default(cuid())
  code      String           @unique // Ej: "PROP-0041" — generado en servidor
  type      CrmContactType
  name      String
  email     String?
  phone     String?
  rut       String?
  notes     String?
  source    CrmLeadSource
  priority  CrmPriority      @default(MEDIUM)
  status    CrmContactStatus @default(ACTIVE)
  brokerId  String
  broker    User             @relation("CrmBrokerContacts", fields: [brokerId], references: [id])
  preferredChannel CrmChannel?

  // Vinculación al sistema NeiFe cuando el arrendatario ya tiene cuenta
  neifeUserId String?

  deals      CrmDealContact[]
  activities CrmActivity[]
  score      CrmContactScore?
  tasks      CrmTask[]            @relation("ContactTasks")
  ownedProperties CrmProperty[] @relation("CrmPropertyOwner")
  whatsappMessages WhatsAppMessage[] @relation("WhatsAppMessages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId, status])
  @@index([code])
}

model CrmProperty {
  id            String            @id @default(cuid())
  code          String            @unique // Ej: "INMU-0089"
  address       String
  commune       String
  type          CrmPropertyType
  bedrooms      Int?
  bathrooms     Int?
  sqMeters      Float?
  operationType CrmOperationType
  askingPrice   Float?
  crmStatus     CrmPropertyStatus @default(LEAD)
  ownerId       String?
  owner         CrmContact?       @relation("CrmPropertyOwner", fields: [ownerId], references: [id])
  brokerId      String
  broker        User              @relation("CrmBrokerProperties", fields: [brokerId], references: [id])
  deals         CrmDeal[]
  notes         String?

  // Vinculación a NeiFe post-firma
  neifePropertyId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId, crmStatus])
}

model CrmDeal {
  id            String          @id @default(cuid())
  code          String          @unique // Ej: "OPE-0055"
  title         String
  stage         CrmDealStage    @default(NUEVO_LEAD)
  phase         CrmPhase        @default(PRE_VENTA)
  operationType CrmOperationType
  value         Float?
  commission    Float?
  brokerId      String
  broker        User            @relation("CrmBrokerDeals", fields: [brokerId], references: [id])
  landlordId    String?
  landlord      User?           @relation("CrmDealLandlord", fields: [landlordId], references: [id])
  propertyId    String?
  property      CrmProperty?    @relation(fields: [propertyId], references: [id])
  contacts      CrmDealContact[]
  activities    CrmActivity[]
  stageHistory  CrmDealStageHistory[]
  attachments   CrmDealAttachment[]
  status        CrmDealStatus   @default(ACTIVE)
  lostReason    String?
  wonAt         DateTime?
  dueDate       DateTime?
  notes         String?

  // Vinculación a NeiFe cuando se gana
  neifeContractId String?

  // PARTE 6 relations
  sequences     CrmDealSequence[] @relation("DealSequences")
  whatsappMessages WhatsAppMessage[] @relation("WhatsAppMessages")
  estimatedValue Float?

  // FASE VIXIEES — Task Engine + Playbook
  tasks              CrmTask[]            @relation("DealTasks")
  playbookSteps      CrmPlaybookCompletion[] @relation("DealPlaybook")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId, status, stage])
  @@index([landlordId])
}

model CrmDealContact {
  id        String      @id @default(cuid())
  dealId    String
  deal      CrmDeal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contactId String
  contact   CrmContact  @relation(fields: [contactId], references: [id])
  role      CrmDealRole
  isPrimary Boolean     @default(false)
  addedAt   DateTime    @default(now())

  @@unique([dealId, contactId])
}

model CrmActivity {
  id          String          @id @default(cuid())
  type        CrmActivityType
  title       String
  description String?
  brokerId    String
  broker      User            @relation("CrmBrokerActivities", fields: [brokerId], references: [id])
  dealId      String?
  deal        CrmDeal?        @relation(fields: [dealId], references: [id])
  contactId   String?
  contact     CrmContact?     @relation(fields: [contactId], references: [id])
  scheduledAt DateTime?
  completedAt DateTime?
  isDone      Boolean         @default(false)
  createdAt   DateTime        @default(now())

  @@index([brokerId, isDone])
  @@index([dealId])
}

// ====== PARTE 6: Deal Sequences ======
model CrmDealSequenceTemplate {
  id               String                 @id @default(cuid())
  brokerId         String
  broker           User                   @relation("SequenceTemplates", fields: [brokerId], references: [id])
  name             String
  description      String?
  actions          Json                   // Array of SequenceAction
  triggerType      String                 @default("MANUAL")
  triggerStage     String?
  triggerCondition Json?
  isActive         Boolean                @default(true)
  sequences        CrmDealSequence[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([brokerId])
}

model CrmDealSequence {
  id          String                      @id @default(cuid())
  dealId      String
  deal        CrmDeal                     @relation("DealSequences", fields: [dealId], references: [id], onDelete: Cascade)
  templateId  String
  template    CrmDealSequenceTemplate     @relation(fields: [templateId], references: [id])
  createdBy   String
  creator     User                        @relation("SequencesCreated", fields: [createdBy], references: [id])
  status      String                      @default("ACTIVE")
  actions     Json                        // Array of executed actions
  startedAt   DateTime?
  pausedAt    DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  cancelledAt DateTime?
  createdAt   DateTime                    @default(now())

  executions CrmDealSequenceExecution[]

  @@index([dealId, status])
}

model CrmDealSequenceExecution {
  id         String             @id @default(cuid())
  sequenceId String
  sequence   CrmDealSequence    @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  action     Json               // SequenceAction
  status     String             @default("PENDING")
  scheduledFor DateTime
  executedAt DateTime?
  result     String?
  createdAt  DateTime           @default(now())

  @@index([sequenceId, status, scheduledFor])
}

// ====== PARTE 6: Integrations ======
model BrokerIntegration {
  id             String  @id @default(cuid())
  brokerId       String
  broker         User    @relation("BrokerIntegrations", fields: [brokerId], references: [id])
  integationType String
  provider       String
  credentials    Json
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([brokerId, integationType])
  @@index([brokerId, integationType])
}

// ====== PARTE 6: WhatsApp Integration ======
model WhatsAppMessage {
  id          String   @id @default(cuid())
  dealId      String?
  deal        CrmDeal? @relation("WhatsAppMessages", fields: [dealId], references: [id])
  contactId   String?
  contact     CrmContact? @relation("WhatsAppMessages", fields: [contactId], references: [id])
  brokerId    String
  broker      User     @relation("WhatsAppMessages", fields: [brokerId], references: [id])
  phoneNumber String
  message     String
  messageId   String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  @@index([dealId, contactId])
  @@index([brokerId, createdAt])
}

model WhatsAppTemplate {
  id       String  @id @default(cuid())
  brokerId String
  broker   User    @relation("WhatsAppTemplates", fields: [brokerId], references: [id])
  name     String
  content  String
  variables String[] // JSON array of variable names
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId, isActive])
  @@unique([brokerId, name])
}

model CrmContactScore {
  id               String     @id @default(cuid())
  contactId        String     @unique
  contact          CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  score            Float      @default(50)
  lastActivityDays Int        @default(0)
  urgencyLevel     String     @default("MEDIUM")
  recommendation   String?
  calculatedAt     DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model CrmDealStageHistory {
  id        String       @id @default(cuid())
  dealId    String
  deal      CrmDeal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStage CrmDealStage?
  toStage   CrmDealStage
  changedAt DateTime     @default(now())
  changedBy String
  broker    User         @relation("StageHistoryBroker", fields: [changedBy], references: [id])

  @@index([dealId])
}

model CrmDealAttachment {
  id        String   @id @default(cuid())
  dealId    String
  deal      CrmDeal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String?
  uploadedBy String
  uploader  User     @relation("DealAttachmentUploader", fields: [uploadedBy], references: [id])
  createdAt DateTime @default(now())

  @@index([dealId])
}

// ─────────────────────────────────────────────────────────────
// FASE VIXIEES — Task Engine + Playbook + Templates
// Agregado: Junio 2026
// ─────────────────────────────────────────────────────────────

model CrmTask {
  id          String       @id @default(cuid())
  brokerId    String
  broker      User         @relation("BrokerTasks", fields: [brokerId], references: [id])
  dealId      String?
  deal        CrmDeal?     @relation("DealTasks", fields: [dealId], references: [id])
  contactId   String?
  contact     CrmContact?  @relation("ContactTasks", fields: [contactId], references: [id])

  type        CrmTaskType
  title       String
  description String?
  channel     CrmChannel?
  dueDate     DateTime
  completedAt DateTime?
  isCompleted Boolean      @default(false)
  isAutomatic Boolean      @default(false) // true = generada por el motor
  priority    Int          @default(0)     // 0=baja, 1=media, 2=alta, 3=crítica

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([brokerId, isCompleted, dueDate])
  @@index([dealId])
}

model CrmPlaybookStep {
  id          String       @id @default(cuid())
  brokerId    String?      // null = step global del sistema
  broker      User?        @relation("BrokerPlaybook", fields: [brokerId], references: [id])

  stage       CrmDealStage
  order       Int
  title       String
  description String?
  taskType    CrmTaskType
  channel     CrmChannel?
  daysDue     Int          @default(1) // días desde inicio de etapa para completar
  isRequired  Boolean      @default(true)
  isActive    Boolean      @default(true)

  completions CrmPlaybookCompletion[]

  createdAt   DateTime     @default(now())

  @@index([stage, order])
  @@unique([stage, order, brokerId])
}

model CrmPlaybookCompletion {
  id         String           @id @default(cuid())
  stepId     String
  step       CrmPlaybookStep  @relation(fields: [stepId], references: [id])
  dealId     String
  deal       CrmDeal          @relation("DealPlaybook", fields: [dealId], references: [id])
  brokerId   String
  completedAt DateTime        @default(now())
  notes      String?

  @@unique([stepId, dealId])
  @@index([dealId])
}

model CrmMessageTemplate {
  id        String   @id @default(cuid())
  brokerId  String
  broker    User     @relation("BrokerMessageTemplates", fields: [brokerId], references: [id])

  name      String
  channel   CrmChannel
  subject   String?  // para email
  body      String   // con {{variables}} interpolables
  variables String[] // lista de variables usadas: ["nombre", "propiedad", "monto"]
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId, channel])
  @@unique([brokerId, name])
}

model BrokerGoal {
  id         String     @id @default(cuid())
  brokerId   String
  broker     User       @relation("BrokerGoals", fields: [brokerId], references: [id])

  period     GoalPeriod
  week       Int?
  month      Int?
  year       Int
  metric     GoalMetric
  target     Float
  unit       String     @default("count")
  commitment String?

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([brokerId, period, metric, week, month, year])
  @@index([brokerId, period, year])
}

model BrokerWeekPlan {
  id               String   @id @default(cuid())
  brokerId         String
  broker           User     @relation("BrokerWeekPlans", fields: [brokerId], references: [id])

  week             Int
  year             Int
  planText         String?  @db.Text
  workDays         Json     @default("{}")
  dailyCommitments Json     @default("{}")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([brokerId, week, year])
  @@index([brokerId, year])
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum GoalMetric {
  CONTACTS
  VISITS
  DEALS_CLOSED
  COMMISSION_CLP
  MANDATES
  PROPERTIES_PUBLISHED
}

// ── Enums CRM ────────────────────────────────────────────────

enum CrmContactType {
  PROPIETARIO
  ARRENDATARIO
  INVERSIONISTA
  LEAD
}

enum CrmLeadSource {
  PORTAL
  REFERIDO
  RRSS
  LLAMADA_DIRECTA
  LETRERO
  OTRO
}

enum CrmPriority {
  HIGH
  MEDIUM
  LOW
}

enum CrmContactStatus {
  ACTIVE
  INACTIVE
  CONVERTED
  LOST
}

enum CrmPropertyType {
  DEPARTAMENTO
  CASA
  OFICINA
  LOCAL_COMERCIAL
  ESTACIONAMIENTO
  OTRO
}

enum CrmOperationType {
  ARRIENDO
  VENTA
  AMBOS
}

enum CrmPropertyStatus {
  LEAD
  CONTACTANDO
  EN_EVALUACION
  MANDATO_FIRMADO
  PUBLICADA
  RESERVADA
  CONVERTIDA
  PERDIDA
}

enum CrmDealStage {
  // PRE-VENTA
  NUEVO_LEAD
  CONTACTO_INICIADO
  VISITA_AGENDADA
  PROPIEDAD_CAPTADA
  // VENTA
  PUBLICADA
  MOSTRANDO
  OFERTA_RECIBIDA
  DOCS_REVISION
  NEGOCIANDO
  // POST-VENTA
  FIRMA_CONTRATO
  ENTREGA_LLAVES
  // CIERRE
  ADMINISTRAR
}

enum CrmPhase {
  PRE_VENTA
  VENTA
  POST_VENTA
}

enum CrmDealStatus {
  ACTIVE
  WON
  LOST
}

enum CrmDealRole {
  PROPIETARIO
  ARRENDATARIO
  AVAL
  OTRO
}

enum CrmActivityType {
  LLAMADA
  VISITA
  EMAIL
  WHATSAPP
  REUNION
  NOTA
  TAREA
  DOCUMENTO
}

enum CrmTaskType {
  LLAMADA
  WHATSAPP
  EMAIL
  VISITA
  REUNION
  DOCUMENTO
  SEGUIMIENTO
  OTRO
}

enum CrmChannel {
  TELEFONO
  WHATSAPP
  EMAIL
  PRESENCIAL
  VIDEO
}
