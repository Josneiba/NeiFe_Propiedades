# NeiFe - Variables de entorno requeridas
# Copia este archivo como .env.local y completa los valores

# Base de datos (Neon PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# NextAuth (genera con: openssl rand -hex 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Cloudinary (para archivos y contratos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (para emails de invitacion y alertas)
RESEND_API_KEY=
RESEND_FROM=invitaciones@tudominio.cl

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NeiFe

# Cron (genera con: openssl rand -hex 32)
CRON_SECRET=thisisthesecretkeyforcrons
