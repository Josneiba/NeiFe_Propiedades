"use client"

import { useState, useRef } from "react"
import { Button } from "@/components/ui/button"
import { Label } from "@/components/ui/label"
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogHeader,
  DialogTitle,
} from "@/components/ui/dialog"
import { Upload, Check } from "lucide-react"
import { cn } from "@/lib/utils"
import { useToast } from "@/hooks/use-toast"

interface PaymentModalProps {
  isOpen: boolean
  onClose: () => void
  payment: {
    month: string
    total: number
    rent: number
    water: number
    electricity: number
    gas?: number
    paymentId?: string
  } | null
  landlord?: {
    name?: string
    bankName?: string
    bankAccountType?: string
    bankAccountNumber?: string
    bankEmail?: string
  } | null
}

type Step = "details" | "upload" | "success"

export function PaymentModal({ isOpen, onClose, payment, landlord }: PaymentModalProps) {
  const [step, setStep] = useState<Step>("details")
  const [uploadedFile, setUploadedFile] = useState<File | null>(null)
  const [isUploading, setIsUploading] = useState(false)
  const [dragActive, setDragActive] = useState(false)
  const fileInputRef = useRef<HTMLInputElement>(null)
  const { toast } = useToast()

  const handleDrag = (e: React.DragEvent) => {
    e.preventDefault()
    e.stopPropagation()
    if (e.type === "dragenter" || e.type === "dragover") {
      setDragActive(true)
    } else if (e.type === "dragleave") {
      setDragActive(false)
    }
  }

  const validateFile = (file: File): boolean => {
    const validTypes = ["image/jpeg", "image/png", "application/pdf"]
    const maxSize = 10 * 1024 * 1024 // 10MB

    if (!validTypes.includes(file.type)) {
      toast({
        title: "Archivo inválido",
        description: "Solo se aceptan JPG, PNG o PDF",
        variant: "destructive",
      })
      return false
    }

    if (file.size > maxSize) {
      toast({
        title: "Archivo muy grande",
        description: "El archivo no debe superar 10MB",
        variant: "destructive",
      })
      return false
    }

    return true
  }

  const handleDrop = (e: React.DragEvent) => {
    e.preventDefault()
    e.stopPropagation()
    setDragActive(false)

    const files = e.dataTransfer.files
    if (files && files[0]) {
      if (validateFile(files[0])) {
        setUploadedFile(files[0])
      }
    }
  }

  const handleFileSelect = (e: React.ChangeEvent<HTMLInputElement>) => {
    const files = e.target.files
    if (files && files[0]) {
      if (validateFile(files[0])) {
        setUploadedFile(files[0])
      }
    }
  }

  const handleUpload = async () => {
    if (!uploadedFile || !payment?.paymentId) return

    setIsUploading(true)
    try {
      const formData = new FormData()
      formData.append("file", uploadedFile)
      formData.append("paymentId", payment.paymentId)

      const uploadRes = await fetch("/api/upload", {
        method: "POST",
        body: formData,
      })

      if (!uploadRes.ok) throw new Error("Upload failed")
      const uploadData = await uploadRes.json()

      const paymentRes = await fetch("/api/payments", {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          paymentId: payment.paymentId,
          status: "PROCESSING",
          receipt: uploadData.url,
        }),
      })

      if (!paymentRes.ok) throw new Error("Payment update failed")

      setStep("success")
      toast({
        title: "Comprobante enviado",
        description: "Tu pago está en revisión",
      })
    } catch (error) {
      toast({
        title: "Error",
        description: "No se pudo enviar el comprobante",
        variant: "destructive",
      })
    } finally {
      setIsUploading(false)
    }
  }

  const handleClose = () => {
    setStep("details")
    setUploadedFile(null)
    onClose()
  }

  if (!payment) return null

  return (
    <Dialog open={isOpen} onOpenChange={handleClose}>
      <DialogContent className="bg-card border-border max-w-lg max-h-[90vh] overflow-y-auto w-[calc(100%-32px)] mx-4 md:mx-auto md:w-full md:max-w-lg">
        <DialogHeader>
          <DialogTitle className="text-foreground">
            {step === "success" ? "Pago enviado" : `Pago - ${payment.month}`}
          </DialogTitle>
          <DialogDescription className="text-muted-foreground">
            {step === "details" && "Detalles de tu pago"}
            {step === "upload" && "Sube el comprobante de transferencia"}
            {step === "success" && "Tu pago está en revisión"}
          </DialogDescription>
        </DialogHeader>

        <div className="space-y-6">
          {/* STEP 1: PAYMENT DETAILS */}
          {step === "details" && (
            <>
              {/* Breakdown */}
              <div className="space-y-3">
                <Label className="text-xs font-semibold text-muted-foreground uppercase">
                  Desglose del Pago
                </Label>
                <div className="p-4 rounded-lg bg-muted space-y-2">
                  <div className="flex justify-between text-sm">
                    <span className="text-muted-foreground">Arriendo:</span>
                    <span className="font-medium">${payment.rent.toLocaleString("es-CL")}</span>
                  </div>
                  {payment.water > 0 && (
                    <div className="flex justify-between text-sm">
                      <span className="text-muted-foreground">Agua:</span>
                      <span className="font-medium">${payment.water.toLocaleString("es-CL")}</span>
                    </div>
                  )}
                  {payment.electricity > 0 && (
                    <div className="flex justify-between text-sm">
                      <span className="text-muted-foreground">Luz:</span>
                      <span className="font-medium">${payment.electricity.toLocaleString("es-CL")}</span>
                    </div>
                  )}
                  {payment.gas && payment.gas > 0 && (
                    <div className="flex justify-between text-sm">
                      <span className="text-muted-foreground">Gas:</span>
                      <span className="font-medium">${payment.gas.toLocaleString("es-CL")}</span>
                    </div>
                  )}
                  <div className="flex justify-between text-base font-bold pt-2 border-t border-border">
                    <span>Total:</span>
                    <span className="text-primary">${payment.total.toLocaleString("es-CL")}</span>
                  </div>
                </div>
              </div>

              {/* Landlord Bank Details */}
              {landlord && (
                <div className="space-y-3">
                  <Label className="text-xs font-semibold text-muted-foreground uppercase">
                    Datos Bancarios del Propietario
                  </Label>
                  <div className="p-4 rounded-lg bg-muted space-y-2 text-sm">
                    {landlord.name && (
                      <div className="flex justify-between">
                        <span className="text-muted-foreground">Nombre:</span>
                        <span className="font-medium">{landlord.name}</span>
                      </div>
                    )}
                    {landlord.bankName && (
                      <div className="flex justify-between">
                        <span className="text-muted-foreground">Banco:</span>
                        <span className="font-medium">{landlord.bankName}</span>
                      </div>
                    )}
                    {landlord.bankAccountType && (
                      <div className="flex justify-between">
                        <span className="text-muted-foreground">Tipo Cuenta:</span>
                        <span className="font-medium">{landlord.bankAccountType}</span>
                      </div>
                    )}
                    {landlord.bankAccountNumber && (
                      <div className="flex justify-between">
                        <span className="text-muted-foreground">Nro. Cuenta:</span>
                        <span className="font-medium font-mono">{landlord.bankAccountNumber}</span>
                      </div>
                    )}
                    {landlord.bankEmail && (
                      <div className="flex justify-between">
                        <span className="text-muted-foreground">Email:</span>
                        <span className="font-medium text-xs break-all">{landlord.bankEmail}</span>
                      </div>
                    )}
                  </div>
                </div>
              )}

              <Button onClick={() => setStep("upload")} className="w-full" size="lg">
                Continuar
              </Button>
            </>
          )}

          {/* STEP 2: RECEIPT UPLOAD */}
          {step === "upload" && (
            <>
              <div className="space-y-3">
                <Label className="text-xs font-semibold text-muted-foreground uppercase">
                  Comprobante de Transferencia
                </Label>

                <div
                  onDragEnter={handleDrag}
                  onDragLeave={handleDrag}
                  onDragOver={handleDrag}
                  onDrop={handleDrop}
                  className={cn(
                    "relative p-8 rounded-lg border-2 border-dashed transition-colors cursor-pointer",
                    dragActive
                      ? "border-primary bg-primary/5"
                      : "border-muted-foreground/20 bg-muted/50 hover:bg-muted"
                  )}
                  onClick={() => fileInputRef.current?.click()}
                >
                  <input
                    ref={fileInputRef}
                    type="file"
                    accept=".jpg,.jpeg,.png,.pdf"
                    onChange={handleFileSelect}
                    className="hidden"
                  />

                  <div className="flex flex-col items-center justify-center text-center">
                    {uploadedFile ? (
                      <>
                        <Check className="h-8 w-8 text-primary mb-2" />
                        <p className="font-medium text-sm">{uploadedFile.name}</p>
                        <p className="text-xs text-muted-foreground mt-1">
                          {(uploadedFile.size / 1024 / 1024).toFixed(2)} MB
                        </p>
                      </>
                    ) : (
                      <>
                        <Upload className="h-8 w-8 text-muted-foreground mb-2" />
                        <p className="font-medium text-sm">Arrastra tu archivo aquí</p>
                        <p className="text-xs text-muted-foreground mt-1">
                          JPG, PNG o PDF (máx. 10MB)
                        </p>
                      </>
                    )}
                  </div>
                </div>

                {uploadedFile && (
                  <Button
                    variant="outline"
                    size="sm"
                    onClick={() => setUploadedFile(null)}
                    className="w-full"
                  >
                    Cambiar archivo
                  </Button>
                )}
              </div>

              <div className="flex gap-2">
                <Button
                  variant="outline"
                  onClick={() => setStep("details")}
                  className="flex-1"
                  disabled={isUploading}
                >
                  Atrás
                </Button>
                <Button
                  onClick={handleUpload}
                  className="flex-1"
                  disabled={!uploadedFile || isUploading}
                >
                  {isUploading ? "Enviando..." : "Enviar"}
                </Button>
              </div>
            </>
          )}

          {/* STEP 3: SUCCESS */}
          {step === "success" && (
            <>
              <div className="flex flex-col items-center justify-center py-8 text-center space-y-3">
                <div className="rounded-full bg-primary/10 p-3">
                  <Check className="h-6 w-6 text-primary" />
                </div>
                <div>
                  <h3 className="font-semibold text-foreground">En Revisión</h3>
                  <p className="text-sm text-muted-foreground mt-1">
                    Tu pago ha sido recibido y está siendo revisado
                  </p>
                </div>
              </div>

              <Button onClick={handleClose} className="w-full">
                Cerrar
              </Button>
            </>
          )}
        </div>
      </DialogContent>
    </Dialog>
  )
}
